{
  "name": "skillrouter",
  "version": "0.0.0",
  "private": true,
  "description": "Local trusted Agent Skill router for LLM agents",
  "type": "module",
  "bin": {
    "skillrouter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "skillrouter": "node dist/cli.js",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "test:integration": "vitest run test/integration",
    "test:unit": "vitest run test/unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/picomatch": "^4.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7",
  "engines": {
    "node": ">=22.13.0"
  }
}
